{
  "name": "todo-sdd-speckit",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/e2e"
  ],
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "postinstall": "npm run build -w @todo/shared",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "e2e": "bash scripts/run-e2e.sh",
    "perf": "npm run playwright -w @todo/e2e -- journeys/performance.spec.ts --project=chromium-mobile",
    "perf:lighthouse": "node scripts/run-lighthouse.mjs",
    "a11y": "npm run test:a11y -w @todo/web && env -u DATABASE_URL npm run playwright -w @todo/e2e -- journeys/a11y-primary-screens.spec.ts --project=chromium-desktop",
    "verify": "npm run ci && npm run contracts:lint && env -u DATABASE_URL npm run perf && npm run a11y",
    "verify:full": "npm run verify && npm run e2e -- --project=chromium-desktop",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "contracts:lint": "node scripts/validate-openapi.mjs"
  },
  "devDependencies": {
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.6.1",
    "@apidevtools/swagger-parser": "^10.1.1",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
