{
  "name": "todo-sdd-speckit",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/e2e"
  ],
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "postinstall": "npm run build -w @todo/shared",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "e2e": "bash scripts/run-e2e.sh",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "contracts:lint": "node scripts/validate-openapi.mjs"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
